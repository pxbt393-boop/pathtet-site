<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900" width="1600" height="900">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#fafbfe"/>
      <stop offset="80%" stop-color="#e8eef7"/>
      <stop offset="100%" stop-color="#d4e0f0"/>
    </radialGradient>
    <filter id="soft">
      <feGaussianBlur stdDeviation="2"/>
    </filter>
    <filter id="blur3">
      <feGaussianBlur stdDeviation="4"/>
    </filter>
    <pattern id="dots" width="30" height="30" patternUnits="userSpaceOnUse">
      <circle cx="15" cy="15" r="0.6" fill="#14224a" opacity="0.08"/>
    </pattern>
  </defs>

  <rect width="1600" height="900" fill="url(#bg)"/>
  <rect width="1600" height="900" fill="url(#dots)"/>

  <!-- Outer Gzhel border -->
  <rect x="12" y="12" width="1576" height="876" fill="none" stroke="#14224a" stroke-width="3" rx="8"/>
  <rect x="20" y="20" width="1560" height="860" fill="none" stroke="#7fa7d4" stroke-width="1" rx="6"/>
  <rect x="28" y="28" width="1544" height="844" fill="none" stroke="#d4e0f0" stroke-width="1" rx="4"/>

  <!-- Corner rosettes top -->
  <g transform="translate(100,100) scale(1.2)" opacity="0.5">
    <path d="M0,-30 C12,-26 20,-10 16,0 C20,10 12,26 0,30 C-12,26 -20,10 -16,0 C-20,-10 -12,-26 0,-30Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-18 C7,-15 12,-6 10,0 C12,6 7,15 0,18 C-7,15 -12,6 -10,0 C-12,-6 -7,-15 0,-18Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="4" fill="#7fa7d4" opacity="0.4"/>
    <path d="M-20,-20 Q-10,-30 0,-25" fill="none" stroke="#d4e0f0" stroke-width="1"/>
    <path d="M20,-20 Q10,-30 0,-25" fill="none" stroke="#d4e0f0" stroke-width="1"/>
  </g>

  <g transform="translate(1500,100) scale(1.2) scale(-1,1)" opacity="0.5">
    <path d="M0,-30 C12,-26 20,-10 16,0 C20,10 12,26 0,30 C-12,26 -20,10 -16,0 C-20,-10 -12,-26 0,-30Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-18 C7,-15 12,-6 10,0 C12,6 7,15 0,18 C-7,15 -12,6 -10,0 C-12,-6 -7,-15 0,-18Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="4" fill="#7fa7d4" opacity="0.4"/>
  </g>

  <g transform="translate(100,800) scale(1.2) scale(1,-1)" opacity="0.5">
    <path d="M0,-30 C12,-26 20,-10 16,0 C20,10 12,26 0,30 C-12,26 -20,10 -16,0 C-20,-10 -12,-26 0,-30Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-18 C7,-15 12,-6 10,0 C12,6 7,15 0,18 C-7,15 -12,6 -10,0 C-12,-6 -7,-15 0,-18Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="4" fill="#7fa7d4" opacity="0.4"/>
  </g>

  <g transform="translate(1500,800) scale(1.2) scale(-1,-1)" opacity="0.5">
    <path d="M0,-30 C12,-26 20,-10 16,0 C20,10 12,26 0,30 C-12,26 -20,10 -16,0 C-20,-10 -12,-26 0,-30Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-18 C7,-15 12,-6 10,0 C12,6 7,15 0,18 C-7,15 -12,6 -10,0 C-12,-6 -7,-15 0,-18Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="4" fill="#7fa7d4" opacity="0.4"/>
  </g>

  <!-- ============ Macro texture: pâté close-up ============ -->

  <!-- Large circular macro view -->
  <circle cx="800" cy="430" r="330" fill="#fafbfe" stroke="#7fa7d4" stroke-width="1.5" opacity="0.6"/>
  <circle cx="800" cy="430" r="320" fill="#fafbfe" opacity="0.4"/>

  <!-- Pâté texture background -->
  <circle cx="800" cy="430" r="310" fill="#e8eef7" opacity="0.3"/>

  <!-- Pâté mass - smooth organic shapes -->
  <g opacity="0.7">
    <!-- Main pâté body -->
    <path d="M540,430 Q580,320 700,340 Q800,310 900,350 Q1020,340 1050,430 Q1080,520 980,560 Q880,590 780,560 Q660,580 560,530 Q520,480 540,430Z" fill="#d4e0f0" opacity="0.5"/>
    <path d="M560,430 Q600,340 710,360 Q800,335 890,370 Q1000,360 1030,430 Q1050,505 960,540 Q860,565 770,540 Q670,555 580,515 Q540,470 560,430Z" fill="#fafbfe" opacity="0.4"/>

    <!-- Spread texture streaks -->
    <path d="M600,400 Q700,370 800,390 Q900,370 1000,400" fill="none" stroke="#7fa7d4" stroke-width="2" opacity="0.2"/>
    <path d="M620,440 Q720,410 820,430 Q920,410 1020,440" fill="none" stroke="#7fa7d4" stroke-width="1.5" opacity="0.15"/>
    <path d="M580,470 Q680,445 780,465 Q880,445 980,475" fill="none" stroke="#d4e0f0" stroke-width="2" opacity="0.25"/>
    <path d="M610,500 Q710,480 810,495 Q910,480 1010,505" fill="none" stroke="#7fa7d4" stroke-width="1.2" opacity="0.12"/>

    <!-- Knife/spread tool -->
    <path d="M780,560 L810,680 L830,680 L800,560Z" fill="#d4e0f0" opacity="0.6"/>
    <rect x="805" y="670" width="30" height="70" rx="5" fill="#14224a" opacity="0.12" transform="rotate(3,820,700)"/>
  </g>

  <!-- Pâté details - little herbs, peppercorns, texture dots -->
  <g opacity="0.3">
    <!-- Herb flecks -->
    <ellipse cx="680" cy="400" rx="6" ry="2" fill="#14224a" opacity="0.2" transform="rotate(30,680,400)"/>
    <ellipse cx="750" cy="380" rx="5" ry="1.5" fill="#14224a" opacity="0.15" transform="rotate(-20,750,380)"/>
    <ellipse cx="850" cy="370" rx="7" ry="2" fill="#14224a" opacity="0.18" transform="rotate(45,850,370)"/>
    <ellipse cx="920" cy="390" rx="5" ry="1.5" fill="#14224a" opacity="0.12" transform="rotate(-10,920,390)"/>
    <ellipse cx="650" cy="450" rx="6" ry="2" fill="#14224a" opacity="0.15" transform="rotate(60,650,450)"/>
    <ellipse cx="950" cy="480" rx="4" ry="1.5" fill="#14224a" opacity="0.12" transform="rotate(-40,950,480)"/>

    <!-- Peppercorns -->
    <circle cx="710" cy="420" r="4" fill="#14224a" opacity="0.2"/>
    <circle cx="830" cy="410" r="3.5" fill="#14224a" opacity="0.18"/>
    <circle cx="890" cy="440" r="4.5" fill="#14224a" opacity="0.15"/>
    <circle cx="760" cy="460" r="3" fill="#14224a" opacity="0.2"/>
    <circle cx="930" cy="420" r="3" fill="#14224a" opacity="0.15"/>
  </g>

  <!-- Fine texture overlay -->
  <g opacity="0.15">
    <circle cx="600" cy="400" r="1" fill="#14224a"/>
    <circle cx="630" cy="430" r="1.2" fill="#14224a"/>
    <circle cx="670" cy="380" r="0.8" fill="#14224a"/>
    <circle cx="720" cy="410" r="1" fill="#14224a"/>
    <circle cx="760" cy="390" r="0.8" fill="#14224a"/>
    <circle cx="800" cy="420" r="1.2" fill="#14224a"/>
    <circle cx="840" cy="400" r="0.8" fill="#14224a"/>
    <circle cx="880" cy="430" r="1" fill="#14224a"/>
    <circle cx="920" cy="400" r="0.8" fill="#14224a"/>
    <circle cx="960" cy="440" r="1" fill="#14224a"/>
    <circle cx="1000" cy="410" r="0.8" fill="#14224a"/>
    <circle cx="650" cy="470" r="1" fill="#14224a"/>
    <circle cx="700" cy="490" r="0.8" fill="#14224a"/>
    <circle cx="850" cy="480" r="1" fill="#14224a"/>
    <circle cx="900" cy="510" r="0.8" fill="#14224a"/>
  </g>

  <!-- Morning light effect -->
  <ellipse cx="700" cy="380" rx="150" ry="100" fill="#fafbfe" opacity="0.2" filter="url(#blur3)"/>

  <!-- ============ Labels ============ -->
  <text x="800" y="160" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="28" fill="#14224a" letter-spacing="4" opacity="0.75">ТЕКСТУРА ПАШТЕТА</text>
  <text x="800" y="190" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="14" fill="#7fa7d4" letter-spacing="2" opacity="0.55">MACRO · КРУПНЫЙ ПЛАН</text>

  <!-- Decorative divider -->
  <g opacity="0.3" transform="translate(700,205)">
    <path d="M0,0 Q50,10 100,0" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <path d="M100,0 Q150,10 200,0" fill="none" stroke="#7fa7d4" stroke-width="1"/>
  </g>

  <!-- Label overlay at bottom -->
  <rect x="650" y="760" width="300" height="40" rx="20" fill="#14224a" opacity="0.08"/>
  <text x="800" y="786" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="14" fill="#14224a" letter-spacing="3" opacity="0.6">ФОТО ПРЕДПРОСМОТР</text>

  <!-- Gzhel floral accent top-left -->
  <g transform="translate(280,240)" opacity="0.25">
    <path d="M0,40 Q20,20 15,-10 Q10,-30 0,-50" fill="none" stroke="#7fa7d4" stroke-width="1.2"/>
    <path d="M15,-10 C30,-20 25,-40 10,-30" fill="none" stroke="#d4e0f0" stroke-width="1"/>
    <circle cx="10" cy="-30" r="8" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <circle cx="10" cy="-30" r="4" fill="#d4e0f0" opacity="0.5"/>
  </g>

  <!-- Gzhel floral accent bottom-right -->
  <g transform="translate(1320,660)" opacity="0.25">
    <path d="M0,-40 Q-20,-20 -15,10 Q-10,30 0,50" fill="none" stroke="#7fa7d4" stroke-width="1.2"/>
    <path d="M-15,10 C-30,20 -25,40 -10,30" fill="none" stroke="#d4e0f0" stroke-width="1"/>
    <circle cx="-10" cy="30" r="8" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <circle cx="-10" cy="30" r="4" fill="#d4e0f0" opacity="0.5"/>
  </g>

  <!-- Arrow overlay indicating spread direction -->
  <g opacity="0.15">
    <path d="M600,530 L500,600" fill="none" stroke="#14224a" stroke-width="2"/>
    <polygon points="500,600 510,590 495,585" fill="#14224a"/>
  </g>
</svg>
