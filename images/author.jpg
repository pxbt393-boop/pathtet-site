<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 800" width="800" height="800">
  <defs>
    <radialGradient id="bg" cx="50%" cy="45%" r="65%">
      <stop offset="0%" stop-color="#fafbfe"/>
      <stop offset="60%" stop-color="#e8eef7"/>
      <stop offset="100%" stop-color="#d4e0f0"/>
    </radialGradient>
    <linearGradient id="warm" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#fafbfe" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#d4e0f0" stop-opacity="0"/>
    </linearGradient>
    <filter id="soft">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
  </defs>

  <rect width="800" height="800" fill="url(#bg)"/>

  <!-- Outer Gzhel border -->
  <rect x="12" y="12" width="776" height="776" fill="none" stroke="#14224a" stroke-width="3" rx="8"/>
  <rect x="20" y="20" width="760" height="760" fill="none" stroke="#7fa7d4" stroke-width="1" rx="6"/>
  <rect x="28" y="28" width="744" height="744" fill="none" stroke="#d4e0f0" stroke-width="1" rx="4"/>

  <!-- Corner elements -->
  <g transform="translate(75,75) scale(0.85)" opacity="0.5">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
    <path d="M-22,-22 C-15,-30 -5,-32 0,-28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <path d="M22,-22 C15,-30 5,-32 0,-28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
  </g>

  <g transform="translate(725,75) scale(0.85) scale(-1,1)" opacity="0.5">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <g transform="translate(75,725) scale(0.85) scale(1,-1)" opacity="0.5">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <g transform="translate(725,725) scale(-1,-1) scale(0.85)" opacity="0.5">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <!-- ============ Portrait illustration ============ -->

  <!-- Portrait oval frame -->
  <ellipse cx="400" cy="380" rx="195" ry="250" fill="#fafbfe" stroke="#7fa7d4" stroke-width="1.5" opacity="0.5"/>
  <ellipse cx="400" cy="380" rx="188" ry="242" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>

  <!-- Shoulders / body silhouette -->
  <path d="M260,580 Q280,480 320,460 Q360,450 400,460 Q440,450 480,460 Q520,480 540,580Z" fill="#d4e0f0" opacity="0.35"/>
  <!-- Dress/blouse with Gzhel pattern -->
  <path d="M270,560 Q290,490 330,470 Q360,460 400,465 Q440,460 470,470 Q510,490 530,560Z" fill="#fafbfe" opacity="0.5"/>
  <!-- Gzhel pattern on blouse -->
  <g opacity="0.15">
    <path d="M330,500 Q350,490 370,500 Q350,510 330,500Z" fill="#7fa7d4"/>
    <path d="M430,500 Q450,490 470,500 Q450,510 430,500Z" fill="#7fa7d4"/>
    <path d="M380,530 Q400,520 420,530 Q400,540 380,530Z" fill="#7fa7d4"/>
  </g>

  <!-- Neck -->
  <rect x="380" y="400" width="40" height="50" rx="8" fill="#d4e0f0" opacity="0.25"/>

  <!-- Head shape -->
  <ellipse cx="400" cy="330" rx="75" ry="90" fill="#fafbfe" opacity="0.6"/>
  <ellipse cx="400" cy="340" rx="72" ry="85" fill="#d4e0f0" opacity="0.2"/>

  <!-- Hair -->
  <path d="M325,300 Q330,220 360,200 Q380,190 400,188 Q420,190 440,200 Q470,220 475,300 Q470,260 460,250 Q440,240 420,238 Q400,237 380,238 Q360,240 340,250 Q330,260 325,300Z" fill="#14224a" opacity="0.15"/>
  <path d="M330,290 Q335,230 360,210 Q380,200 400,198 Q420,200 440,210 Q465,230 470,290" fill="none" stroke="#14224a" stroke-width="1.5" opacity="0.1"/>

  <!-- Face features (stylized) -->
  <g opacity="0.2">
    <!-- Eyes -->
    <ellipse cx="375" cy="325" rx="8" ry="4" fill="#14224a"/>
    <ellipse cx="425" cy="325" rx="8" ry="4" fill="#14224a"/>
    <!-- Eyebrows -->
    <path d="M365,314 Q375,310 385,314" fill="none" stroke="#14224a" stroke-width="1"/>
    <path d="M415,314 Q425,310 435,314" fill="none" stroke="#14224a" stroke-width="1"/>
    <!-- Nose -->
    <path d="M400,320 L398,342 Q400,346 402,342Z" fill="none" stroke="#14224a" stroke-width="0.8"/>
    <!-- Smile -->
    <path d="M385,355 Q400,365 415,355" fill="none" stroke="#14224a" stroke-width="1"/>
  </g>

  <!-- Warm glow on face -->
  <ellipse cx="400" cy="320" rx="60" ry="70" fill="url(#warm)" opacity="0.3"/>

  <!-- Hands holding a jar -->
  <g opacity="0.25">
    <!-- Left hand -->
    <path d="M280,530 Q300,520 320,540 Q330,550 310,560 Q290,560 280,550Z" fill="#d4e0f0"/>
    <!-- Right hand -->
    <path d="M520,530 Q500,520 480,540 Q470,550 490,560 Q510,560 520,550Z" fill="#d4e0f0"/>
    <!-- Small jar being held -->
    <rect x="370" y="490" width="60" height="65" rx="6" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1" opacity="0.6"/>
    <rect x="380" y="535" width="40" height="15" rx="3" fill="#d4e0f0" opacity="0.3"/>
    <circle cx="400" cy="490" r="25" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1" opacity="0.5"/>
  </g>

  <!-- Kitchen background elements -->
  <g opacity="0.08">
    <!-- Shelf -->
    <rect x="120" y="200" width="180" height="6" rx="3" fill="#14224a"/>
    <rect x="500" y="180" width="160" height="6" rx="3" fill="#14224a"/>
    <!-- Jar outlines on shelf -->
    <rect x="140" y="150" width="35" height="50" rx="5" fill="none" stroke="#14224a" stroke-width="1"/>
    <rect x="190" y="160" width="30" height="40" rx="4" fill="none" stroke="#14224a" stroke-width="1"/>
    <rect x="250" y="145" width="35" height="55" rx="5" fill="none" stroke="#14224a" stroke-width="1"/>
    <rect x="520" y="135" width="40" height="45" rx="5" fill="none" stroke="#14224a" stroke-width="1"/>
    <rect x="575" y="145" width="30" height="35" rx="4" fill="none" stroke="#14224a" stroke-width="1"/>
  </g>

  <!-- ============ Title ============ -->
  <text x="400" y="145" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="28" fill="#14224a" letter-spacing="4" opacity="0.75">АНАСТАСИЯ</text>
  <text x="400" y="170" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="13" fill="#7fa7d4" letter-spacing="3" opacity="0.55">АВТОР РЕЦЕПТА</text>

  <!-- Decorative line under title -->
  <g opacity="0.3" transform="translate(290,182)">
    <path d="M0,0 Q55,8 110,0" fill="none" stroke="#7fa7d4" stroke-width="1"/>
  </g>

  <!-- Label -->
  <rect x="270" y="720" width="260" height="36" rx="18" fill="#14224a" opacity="0.07"/>
  <text x="400" y="743" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="13" fill="#14224a" letter-spacing="2" opacity="0.55">ФОТО ПРЕДПРОСМОТР</text>

  <!-- Gzhel floral accent -->
  <g transform="translate(640,300)" opacity="0.2">
    <path d="M0,40 Q-12,25 -8,0 Q-4,-15 0,-30" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <path d="M-8,0 C-15,-12 -12,-28 -4,-20" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <circle cx="-4" cy="-20" r="5" fill="none" stroke="#7fa7d4" stroke-width="0.8"/>
    <circle cx="-4" cy="-20" r="2.5" fill="#d4e0f0" opacity="0.4"/>
  </g>

  <g transform="translate(160,300) scale(-1,1)" opacity="0.2">
    <path d="M0,40 Q-12,25 -8,0 Q-4,-15 0,-30" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <path d="M-8,0 C-15,-12 -12,-28 -4,-20" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <circle cx="-4" cy="-20" r="5" fill="none" stroke="#7fa7d4" stroke-width="0.8"/>
    <circle cx="-4" cy="-20" r="2.5" fill="#d4e0f0" opacity="0.4"/>
  </g>
</svg>
