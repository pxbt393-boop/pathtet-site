<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 800" width="800" height="800">
  <defs>
    <radialGradient id="bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#fafbfe"/>
      <stop offset="70%" stop-color="#e8eef7"/>
      <stop offset="100%" stop-color="#d4e0f0"/>
    </radialGradient>
    <linearGradient id="wood" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#d4e0f0"/>
      <stop offset="50%" stop-color="#e8eef7"/>
      <stop offset="100%" stop-color="#c8d4e4"/>
    </linearGradient>
    <linearGradient id="glass" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#fafbfe" stop-opacity="0.9"/>
      <stop offset="50%" stop-color="#d4e0f0" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#fafbfe" stop-opacity="0.6"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3"/>
    </filter>
    <pattern id="woodgrain" width="60" height="20" patternUnits="userSpaceOnUse">
      <path d="M0,5 Q15,0 30,5 Q45,10 60,5" fill="none" stroke="#7fa7d4" stroke-width="0.5" opacity="0.15"/>
      <path d="M0,15 Q15,10 30,15 Q45,20 60,15" fill="none" stroke="#7fa7d4" stroke-width="0.3" opacity="0.1"/>
    </pattern>
  </defs>

  <rect width="800" height="800" fill="url(#bg)"/>

  <!-- Outer border -->
  <rect x="12" y="12" width="776" height="776" fill="none" stroke="#14224a" stroke-width="3" rx="8"/>
  <rect x="20" y="20" width="760" height="760" fill="none" stroke="#7fa7d4" stroke-width="1" rx="6"/>
  <rect x="28" y="28" width="744" height="744" fill="none" stroke="#d4e0f0" stroke-width="1" rx="4"/>

  <!-- Corner Gzhel rosettes -->
  <g transform="translate(75,75) scale(0.9)" opacity="0.55">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
    <path d="M-22,-22 C-15,-30 -5,-32 0,-28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <path d="M22,-22 C15,-30 5,-32 0,-28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <path d="M-22,22 C-15,30 -5,32 0,28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <path d="M22,22 C15,30 5,32 0,28" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
  </g>

  <g transform="translate(725,75) scale(0.9) scale(-1,1)" opacity="0.55">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <g transform="translate(75,725) scale(0.9) scale(1,-1)" opacity="0.55">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <g transform="translate(725,725) scale(-1,-1) scale(0.9)" opacity="0.55">
    <path d="M0,-35 C14,-30 22,-12 18,0 C22,12 14,30 0,35 C-14,30 -22,12 -18,0 C-22,-12 -14,-30 0,-35Z" fill="none" stroke="#7fa7d4" stroke-width="1.5"/>
    <path d="M0,-22 C9,-18 14,-8 12,0 C14,8 9,18 0,22 C-9,18 -14,8 -12,0 C-14,-8 -9,-18 0,-22Z" fill="#d4e0f0" opacity="0.5"/>
    <circle cx="0" cy="0" r="5" fill="#7fa7d4" opacity="0.35"/>
  </g>

  <!-- ============ Main illustration: Jars on wooden table ============ -->

  <!-- Wooden table surface -->
  <rect x="60" y="540" width="680" height="180" rx="6" fill="url(#wood)" opacity="0.7"/>
  <rect x="60" y="540" width="680" height="180" fill="url(#woodgrain)" opacity="0.5"/>
  <!-- Table edge -->
  <path d="M60,540 Q400,550 740,540" fill="none" stroke="#7fa7d4" stroke-width="1.5" opacity="0.4"/>
  <path d="M60,545 Q400,555 740,545" fill="none" stroke="#d4e0f0" stroke-width="0.8" opacity="0.3"/>
  <!-- Wood rings -->
  <ellipse cx="300" cy="620" rx="80" ry="20" fill="none" stroke="#7fa7d4" stroke-width="0.5" opacity="0.1"/>
  <ellipse cx="550" cy="640" rx="60" ry="15" fill="none" stroke="#7fa7d4" stroke-width="0.5" opacity="0.08"/>

  <!-- ============ Main jar (center) ============ -->
  <g transform="translate(400,390)">
    <!-- Shadow -->
    <ellipse cx="0" cy="150" rx="90" ry="18" fill="#14224a" opacity="0.1"/>
    <ellipse cx="0" cy="150" rx="70" ry="12" fill="#14224a" opacity="0.08"/>

    <!-- Jar body -->
    <path d="M-75,-50 Q-85,40 -70,140 Q-65,160 0,160 Q65,160 70,140 Q85,40 75,-50Z" fill="url(#glass)" stroke="#7fa7d4" stroke-width="1.2"/>
    <path d="M-75,-50 Q-85,40 -70,140 Q-65,160 0,160 Q65,160 70,140 Q85,40 75,-50Z" fill="#fafbfe" opacity="0.15"/>

    <!-- Pâté inside jar -->
    <path d="M-70,-20 Q-80,50 -68,135 Q-63,152 0,152 Q63,152 68,135 Q80,50 70,-20Z" fill="#e8eef7" opacity="0.5"/>
    <path d="M-66,-10 Q-74,40 -64,110 Q-60,130 0,130 Q60,130 64,110 Q74,40 66,-10Z" fill="#d4e0f0" opacity="0.3"/>
    <!-- Pâté top surface -->
    <ellipse cx="0" cy="-20" rx="68" ry="18" fill="#d4e0f0" opacity="0.4"/>
    <ellipse cx="0" cy="-22" rx="55" ry="12" fill="#fafbfe" opacity="0.25"/>

    <!-- Jar neck -->
    <rect x="-55" y="-90" width="110" height="45" rx="5" fill="#fafbfe" stroke="#7fa7d4" stroke-width="1.2"/>
    <!-- Inner neck highlight -->
    <rect x="-50" y="-85" width="100" height="35" rx="4" fill="#fafbfe" opacity="0.3"/>

    <!-- Twine around neck -->
    <path d="M-55,-60 Q0,-55 55,-60" fill="none" stroke="#7fa7d4" stroke-width="2" opacity="0.3"/>
    <path d="M-55,-56 Q0,-51 55,-56" fill="none" stroke="#d4e0f0" stroke-width="1.5" opacity="0.2"/>

    <!-- Lid (wax paper / fabric top) -->
    <circle cx="0" cy="-105" r="42" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1" opacity="0.8"/>
    <circle cx="0" cy="-105" r="35" fill="#d4e0f0" opacity="0.15"/>
    <!-- Lid decorative Gzhel pattern -->
    <g opacity="0.3">
      <circle cx="0" cy="-105" r="15" fill="none" stroke="#7fa7d4" stroke-width="0.8"/>
      <path d="M-8,-113 Q0,-120 8,-113 Q0,-106 -8,-113Z" fill="#7fa7d4" opacity="0.4"/>
      <path d="M-8,-97 Q0,-90 8,-97 Q0,-104 -8,-97Z" fill="#7fa7d4" opacity="0.4"/>
    </g>

    <!-- Label on jar -->
    <rect x="-45" y="-10" width="90" height="55" rx="3" fill="#fafbfe" opacity="0.7" stroke="#d4e0f0" stroke-width="0.8"/>
    <text x="0" y="10" text-anchor="middle" font-family="Georgia, serif" font-size="8" fill="#14224a" opacity="0.5">НЕГЛИЖЕ</text>
    <text x="0" y="22" text-anchor="middle" font-family="Georgia, serif" font-size="6" fill="#7fa7d4" opacity="0.4">ПАШТЕТ</text>
    <path d="M-30,30 L30,30" stroke="#d4e0f0" stroke-width="0.5" opacity="0.4"/>
    <circle cx="0" cy="38" r="3" fill="none" stroke="#7fa7d4" stroke-width="0.5" opacity="0.3"/>
    <circle cx="0" cy="38" r="1.5" fill="#d4e0f0" opacity="0.3"/>

    <!-- Glass highlights -->
    <path d="M-55,-40 Q-65,30 -55,120" fill="none" stroke="#fafbfe" stroke-width="2" opacity="0.25"/>
    <path d="M-50,-35 Q-58,30 -50,100" fill="none" stroke="#fafbfe" stroke-width="1" opacity="0.15"/>
  </g>

  <!-- ============ Small jar (left) ============ -->
  <g transform="translate(250,420) scale(0.65)">
    <ellipse cx="0" cy="135" rx="65" ry="14" fill="#14224a" opacity="0.08"/>
    <path d="M-55,-40 Q-63,30 -52,125 Q-48,140 0,140 Q48,140 52,125 Q63,30 55,-40Z" fill="url(#glass)" stroke="#d4e0f0" stroke-width="1.2"/>
    <path d="M-51,-10 Q-58,35 -49,110 Q-45,130 0,130 Q45,130 49,110 Q58,35 51,-10Z" fill="#e8eef7" opacity="0.4"/>
    <rect x="-40" y="-70" width="80" height="35" rx="4" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1"/>
    <circle cx="0" cy="-85" r="32" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1" opacity="0.7"/>
    <rect x="-30" y="0" width="60" height="40" rx="3" fill="#fafbfe" opacity="0.5"/>
    <path d="M-38,-30 Q-46,25 -38,95" fill="none" stroke="#fafbfe" stroke-width="1.5" opacity="0.2"/>
  </g>

  <!-- ============ Small jar (right) ============ -->
  <g transform="translate(560,430) scale(0.58)">
    <ellipse cx="0" cy="135" rx="65" ry="14" fill="#14224a" opacity="0.08"/>
    <path d="M-55,-40 Q-63,30 -52,125 Q-48,140 0,140 Q48,140 52,125 Q63,30 55,-40Z" fill="url(#glass)" stroke="#d4e0f0" stroke-width="1.2"/>
    <path d="M-51,-10 Q-58,35 -49,110 Q-45,130 0,130 Q45,130 49,110 Q58,35 51,-10Z" fill="#e8eef7" opacity="0.4"/>
    <rect x="-40" y="-70" width="80" height="35" rx="4" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1"/>
    <circle cx="0" cy="-85" r="32" fill="#fafbfe" stroke="#d4e0f0" stroke-width="1" opacity="0.7"/>
    <rect x="-30" y="0" width="60" height="40" rx="3" fill="#fafbfe" opacity="0.5"/>
    <path d="M38,-30 Q46,25 38,95" fill="none" stroke="#fafbfe" stroke-width="1.5" opacity="0.2"/>
  </g>

  <!-- ============ Scattered herb sprigs on table ============ -->
  <g opacity="0.25">
    <path d="M180,580 Q200,570 220,575 Q240,565 250,580" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <ellipse cx="190" cy="575" rx="3" ry="1.5" fill="#14224a" transform="rotate(20,190,575)"/>
    <ellipse cx="210" cy="572" rx="3" ry="1.5" fill="#14224a" transform="rotate(-10,210,572)"/>
    <ellipse cx="230" cy="573" rx="3" ry="1.5" fill="#14224a" transform="rotate(30,230,573)"/>

    <path d="M570,590 Q590,580 610,585" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <ellipse cx="580" cy="585" rx="3" ry="1.5" fill="#14224a" transform="rotate(-15,580,585)"/>
    <ellipse cx="600" cy="583" rx="3" ry="1.5" fill="#14224a" transform="rotate(25,600,583)"/>
  </g>

  <!-- ============ Title ============ -->
  <text x="400" y="130" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="32" fill="#14224a" letter-spacing="4" opacity="0.8">БАНКИ ПАШТЕТА</text>
  <text x="400" y="158" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="13" fill="#7fa7d4" letter-spacing="3" opacity="0.55">НА ДЕРЕВЯННОМ СТОЛЕ</text>

  <!-- Decorative scroll under title -->
  <g opacity="0.3" transform="translate(280,170)">
    <path d="M0,0 Q60,12 120,0" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <path d="M0,4 Q60,16 120,4" fill="none" stroke="#d4e0f0" stroke-width="0.6"/>
  </g>

  <!-- Bottom label -->
  <rect x="270" y="710" width="260" height="36" rx="18" fill="#14224a" opacity="0.07"/>
  <text x="400" y="733" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="13" fill="#14224a" letter-spacing="2" opacity="0.55">ФОТО ПРЕДПРОСМОТР</text>

  <!-- Gzhel floral accent top -->
  <g transform="translate(160,250)" opacity="0.2">
    <path d="M0,50 Q15,30 10,0 Q5,-20 0,-40" fill="none" stroke="#7fa7d4" stroke-width="1.2"/>
    <path d="M10,0 C20,-15 15,-35 5,-25" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <circle cx="5" cy="-25" r="6" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <circle cx="5" cy="-25" r="3" fill="#d4e0f0" opacity="0.4"/>
  </g>

  <g transform="translate(640,250) scale(-1,1)" opacity="0.2">
    <path d="M0,50 Q15,30 10,0 Q5,-20 0,-40" fill="none" stroke="#7fa7d4" stroke-width="1.2"/>
    <path d="M10,0 C20,-15 15,-35 5,-25" fill="none" stroke="#d4e0f0" stroke-width="0.8"/>
    <circle cx="5" cy="-25" r="6" fill="none" stroke="#7fa7d4" stroke-width="1"/>
    <circle cx="5" cy="-25" r="3" fill="#d4e0f0" opacity="0.4"/>
  </g>
</svg>
